# Core chat provider
GROQ_API_KEY=your_groq_api_key
MODEL=llama-3.1-8b-instant
GROQ_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile
INJECTION_MODEL=openai/gpt-oss-safeguard-20b

# Optional external recipe provider
API_NINJAS_API_KEY=your_api_ninjas_key

# Supabase auth
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Session and cookie settings
SESSION_SECRET=replace_with_a_long_random_secret
COOKIE_SECURE=0

# App/runtime
NODE_ENV=development
CANONICAL_ORIGIN=http://localhost:8000
ALLOWED_HOSTS=localhost:8000,127.0.0.1:8000
TRUSTED_PROXY_IPS=127.0.0.1,::1

# Optional debugging
CHAT_DEBUG_SOURCES=0
RECIPES_DB_PATH=data/recipes.json
